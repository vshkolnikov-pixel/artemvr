  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0427\u0442\u043E\u0431\u044B \u0432\u0437\u044F\u0442\u044C \u043E\u0431\u044A\u0435\u043A\u0442,
    \u043D\u0430\u0432\u0435\u0434\u0438\u0442\u0435 \u043D\u0430 \u043D\u0435\u0433\u043E
    \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u043B\u0435\u0440, \u043D\u0430\u0436\u043C\u0438\u0442\u0435
    \u0438 \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439\u0442\u0435 \u043A\u0443\u0440\u043E\u043A
    (\u0442\u0440\u0438\u0433\u0433\u0435\u0440). \u0412\u044B \u0441\u043C\u043E\u0436\u0435\u0442\u0435
    \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0430\u0442\u044C \u043E\u0431\u044A\u0435\u043A\u0442
    \u0432 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435.
    \u0427\u0442\u043E\u0431\u044B \u043E\u0442\u043F\u0443\u0441\u0442\u0438\u0442\u044C
    \u2013 \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u043F\u0443\u0441\u0442\u0438\u0442\u0435
    \u043A\u0443\u0440\u043E\u043A. \u041B\u0443\u0447 \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442
    \u043F\u0440\u0438\u0446\u0435\u043B\u0438\u0442\u044C\u0441\u044F, \u043D\u043E
    \u0445\u0432\u0430\u0442\u0430\u0442\u044C \u043D\u0443\u0436\u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E
    \u043D\u0430\u0436\u0430\u0442\u0438\u0435\u043C. \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435
    \u0432\u0437\u044F\u0442\u044C \u043B\u044E\u0431\u043E\u0439 \u043F\u0440\u0435\u0434\u043C\u0435\u0442
    \u2013 \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0448\u0430\u0440."
