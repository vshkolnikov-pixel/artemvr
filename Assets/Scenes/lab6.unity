--- !u!114 &2072766331
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2072766329}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9541d86e2fd84c1d9990edf0852d74ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412\u043E\u0437\u044C\u043C\u0438\u0442\u0435 \u043B\u0443\u0447\u043E\u043C
    \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u043B\u0435\u0440\u0430 \u0434\u0435\u0440\u0435\u0432\u044F\u043D\u043D\u044B\u0439
    \u0431\u0440\u0443\u0441\u043E\u043A \u043C\u0430\u0441\u0441\u043E\u0439 1 \u043A\u0433,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0432\u043D\u0438\u0437\u0443 \u043D\u0430\u043A\u043B\u043E\u043D\u043D\u043E\u0439
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438, \u0438 \u043F\u0440\u0438\u043A\u0440\u0435\u043F\u0438\u0442\u0435
    \u043A \u043D\u0435\u043C\u0443 \u0434\u0438\u043D\u0430\u043C\u043E\u043C\u0435\u0442\u0440
    \u2013 \u0441\u0438\u043D\u0438\u0439 \u043F\u0440\u0438\u0431\u043E\u0440 \u0441
    \u0446\u0438\u0444\u0440\u0430\u043C\u0438: \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E
    \u0437\u0430\u0445\u0432\u0430\u0442\u0438\u0442\u0435 \u0434\u0438\u043D\u0430\u043C\u043E\u043C\u0435\u0442\u0440
    \u0438 \u043F\u043E\u0434\u043D\u0435\u0441\u0438\u0442\u0435 \u0435\u0433\u043E
    \u043A\u0440\u044E\u043A\u043E\u043C \u043A \u0431\u0440\u0443\u0441\u043A\u0443,
    \u043F\u0440\u043E\u0438\u0437\u043E\u0439\u0434\u0451\u0442 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0441\u0446\u0435\u043F\u043B\u0435\u043D\u0438\u0435. \u0417\u0430\u0442\u0435\u043C,
    \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044F \u0434\u0438\u043D\u0430\u043C\u043E\u043C\u0435\u0442\u0440,
    \u043D\u0430\u0447\u043D\u0438\u0442\u0435 \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E
    \u0442\u044F\u043D\u0443\u0442\u044C \u0431\u0440\u0443\u0441\u043E\u043A \u0432\u0432\u0435\u0440\u0445
    \u043F\u043E \u043D\u0430\u043A\u043B\u043E\u043D\u043D\u043E\u0439 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438,
    \u0441\u043B\u0435\u0434\u044F \u0437\u0430 \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u0438\u0435\u043C
    \u0434\u0438\u043D\u0430\u043C\u043E\u043C\u0435\u0442\u0440\u0430 \u2013 \u044D\u0442\u043E
    \u0441\u0438\u043B\u0430 \u0442\u044F\u0433\u0438 F, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0437\u0430 \u0440\u0443\u043B\u0435\u0442\u043A\u043E\u0439 (\u043B\u0435\u043D\u0442\u0430
    \u0432\u0434\u043E\u043B\u044C \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438),
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u044E\u0449\u0435\u0439 \u043F\u0440\u043E\u0439\u0434\u0435\u043D\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C S, \u0438 \u0437\u0430 \u0432\u044B\u0441\u043E\u0442\u043E\u0439
    \u043F\u043E\u0434\u044A\u0451\u043C\u0430 h, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043D\u0430 \u044D\u043A\u0440\u0430\u043D\u0435.
    \u0414\u0432\u0438\u0433\u0430\u0439\u0442\u0435 \u0431\u0440\u0443\u0441\u043E\u043A
    \u0434\u043E \u0432\u0435\u0440\u0445\u043D\u0435\u0439 \u0442\u043E\u0447\u043A\u0438
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438, \u043F\u043E\u0441\u043B\u0435
    \u0447\u0435\u0433\u043E \u0437\u0430\u043F\u0438\u0448\u0438\u0442\u0435 \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u0441\u0438\u043B\u044B , \u043F\u0443\u0442\u0438
    \u0438 \u0432\u044B\u0441\u043E\u0442\u044B. \u0420\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u0439\u0442\u0435
    \u043F\u043E\u043B\u0435\u0437\u043D\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    A\u043F\u043E\u043B = m\xB7g\xB7h \u0438 \u043F\u043E\u043B\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 A\u0437\u0430\u0442\u0440 = F\xB7S, \u0437\u0430\u0442\u0435\u043C
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435 \u041A\u041F\u0414 \u043F\u043E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0435 \u03B7 = (A\u043F\u043E\u043B / A\u0437\u0430\u0442\u0440)
    \xB7 100%. \u041F\u043E\u0441\u043B\u0435 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430
    \u043E\u0442\u0446\u0435\u043F\u0438\u0442\u0435 \u0434\u0438\u043D\u0430\u043C\u043E\u043C\u0435\u0442\u0440
    \u043E\u0442 \u0431\u0440\u0443\u0441\u043A\u0430, \u0432\u0435\u0440\u043D\u0438\u0442\u0435
    \u0431\u0440\u0443\u0441\u043E\u043A \u0432 \u0438\u0441\u0445\u043E\u0434\u043D\u043E\u0435
    \u043D\u0438\u0436\u043D\u0435\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0438 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435 \u0434\u0438\u043D\u0430\u043C\u043E\u043C\u0435\u0442\u0440
    \u043D\u0430 \u043C\u0435\u0441\u0442\u043E; \u043F\u0440\u0438 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438
    \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u043A\u043D\u043E\u043F\u043A\u0443
    \xAB\u0421\u0431\u0440\u043E\u0441\xBB \u043D\u0430 \u043F\u0430\u043D\u0435\u043B\u0438
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F.\r\n\r\n"
  m_isRightToLeft: 0
