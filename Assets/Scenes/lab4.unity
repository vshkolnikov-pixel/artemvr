    \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u044B\u0445 \u0441\u0438\u043D\u0438\u043C\u0438
    \u043C\u0430\u0440\u043A\u0435\u0440\u0430\u043C\u0438 \u2013 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u043E\u0442 \u043E\u0441\u0438 (0,3 \u043C, 0,6 \u043C \u0438\u043B\u0438 0,9
    \u043C) \u0443\u043A\u0430\u0437\u0430\u043D\u043E \u043D\u0430\u0434 \u0442\u043E\u0447\u043A\u043E\u0439.
    \u0417\u0430\u0442\u0435\u043C \u043F\u043E \u043E\u0447\u0435\u0440\u0435\u0434\u0438
    \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0439\u0442\u0435 \u0433\u0440\u0443\u0437\u044B
    \u0438 \u043A\u043B\u0430\u0434\u0438\u0442\u0435 \u0438\u0445 \u043D\u0430 \u0442\u043E\u0447\u043A\u0438
    \u043F\u0440\u0430\u0432\u043E\u0433\u043E \u043F\u043B\u0435\u0447\u0430 (\u0440\u043E\u0437\u043E\u0432\u044B\u0435
    \u043C\u0430\u0440\u043A\u0435\u0440\u044B), \u043F\u043E\u043A\u0430 \u0440\u044B\u0447\u0430\u0433
    \u043D\u0435 \u043F\u0440\u0438\u0434\u0451\u0442 \u0432 \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435.
    \u041A\u0430\u0436\u0434\u044B\u0439 \u0433\u0440\u0443\u0437 \u0431\u0435\u0440\u0438\u0442\u0435
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E, \u0441\u043B\u0435\u0434\u044F
    \u0437\u0430 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C \u0440\u044B\u0447\u0430\u0433\u0430,
    \u0438 \u043D\u0435 \u0432\u0435\u0448\u0430\u0439\u0442\u0435 \u0431\u043E\u043B\u044C\u0448\u0435
    \u0442\u0440\u0451\u0445 \u0433\u0440\u0443\u0437\u043E\u0432 \u0441 \u043A\u0430\u0436\u0434\u043E\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B,. \u041A\u043E\u0433\u0434\u0430 \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0433\u043D\u0443\u0442\u043E, \u0437\u0430\u043F\u0438\u0448\u0438\u0442\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u043C\u0430\u0441\u0441 \u0438
    \u043F\u043B\u0435\u0447 \u0434\u043B\u044F \u043B\u0435\u0432\u043E\u0439 \u0438
    \u043F\u0440\u0430\u0432\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D, \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435
    \u0441\u0443\u043C\u043C\u0443 \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432
    \u0441\u0438\u043B (\u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0441\u0438\u043B\u044B \u0442\u044F\u0436\u0435\u0441\u0442\u0438 \u043D\u0430
    \u043F\u043B\u0435\u0447\u043E) \u0441\u043B\u0435\u0432\u0430 \u0438 \u0441\u043F\u0440\u0430\u0432\u0430
    \u2013 \u043E\u043D\u0438 \u0434\u043E\u043B\u0436\u043D\u044B \u0431\u044B\u0442\u044C
    \u0440\u0430\u0432\u043D\u044B, \u0447\u0442\u043E \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432.
    \u041F\u043E\u0441\u043B\u0435 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430
    \u0441\u043D\u0438\u043C\u0438\u0442\u0435 \u0432\u0441\u0435 \u0433\u0440\u0443\u0437\u044B
    \u0441 \u0440\u044B\u0447\u0430\u0433\u0430\r\n\r\n"
